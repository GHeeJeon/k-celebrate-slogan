{
    "name": "k-celebrate-slogan",
    "version": "1.1.6",
    "description": "A celebratory slogan component with animated pinwheels.",
    "homepage": "https://k-celebrate-slogan.vercel.app/",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest",
        "preview": "vite",
        "demo": "vite --open /",
        "svg:preview": "vite --open /svg-preview.html",
        "build:demo": "vite build",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
        "format": "prettier --write .",
        "prepare": "husky"
    },
    "keywords": [
        "react",
        "celebrate",
        "slogan",
        "pinwheel",
        "animation"
    ],
    "author": "GHeeJeon",
    "license": "MIT",
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/GHeeJeon/k-celebrate-slogan.git"
    },
    "peerDependencies": {
        "framer-motion": ">=4.0.0",
        "react": ">=16.0.0",
        "react-dom": ">=16.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitejs/plugin-react": "^5.1.3",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "framer-motion": "^10.0.0",
        "husky": "^9.1.7",
        "jsdom": "^28.0.0",
        "lint-staged": "^16.3.1",
        "prettier": "^3.8.1",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    }
}
